#
# Functional tests for the `OPTIONS (ISOLATION LEVEL SNAPSHOT)` query option. YAMSQL cannot exercise
# true concurrency, so these verify that the option parses, plans, and executes without error and
# returns the correct results for a variety of query shapes, and that it is rejected on non-SELECT
# statements. The actual "no conflict range" behavior is verified in SnapshotIsolationConcurrencyTest.
---
options:
    supported_version: !current_version
---
schema_template:
    create table t1(id bigint, col1 bigint, col2 bigint, primary key(id))
    create table t2(id bigint, name string, primary key(id))
    create index mv_max_ever as select max_ever(col2) from t1
    create index mv_max_ever_grp as select max_ever(col2) from t1 group by col1
    create index mv_sum_grp as select sum(col2) from t1 group by col1
---
setup:
  steps:
    - query: INSERT INTO t1
        VALUES (1, 10, 5),
               (2, 10, 7),
               (3, 10, 3),
               (4, 20, 8),
               (5, 20, 2)
    - query: INSERT INTO t2
        VALUES (10, 'ten'),
               (20, 'twenty')
---
test_block:
  name: snapshot-isolation-aggregates
  tests:
    -
      # Atomic aggregate index (the target zone-key-mapping use case).
      - query: select max_ever(col2) from t1 OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - result: [{!l 8}]
    -
      # Grouped atomic aggregate index at snapshot isolation.
      - query: select col1, max_ever(col2) from t1 group by col1 OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - unorderedResult: [{!l 10, !l 7}, {!l 20, !l 8}]
    -
      # Streaming aggregate (no aggregate index) at snapshot isolation.
      - query: select sum(col2) from t1 OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - result: [{!l 25}]
    -
      # Grouped streaming aggregate at snapshot isolation.
      - query: select col1, sum(col2) from t1 group by col1 OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - unorderedResult: [{!l 10, !l 15}, {!l 20, !l 10}]
    -
      # Grouped aggregate with HAVING at snapshot isolation.
      - query: select col1, sum(col2) from t1 group by col1 having sum(col2) > 12 OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - unorderedResult: [{!l 10, !l 15}]
---
test_block:
  name: snapshot-isolation-non-aggregate
  tests:
    -
      # Point lookup at snapshot isolation.
      - query: select id, col1, col2 from t1 where id = 1 OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - result: [{!l 1, !l 10, !l 5}]
    -
      # Range scan at snapshot isolation.
      - query: select id from t1 where id > 3 OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - unorderedResult: [{!l 4}, {!l 5}]
    -
      # Ordered scan at snapshot isolation.
      - query: select id from t1 order by id OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - result: [{!l 1}, {!l 2}, {!l 3}, {!l 4}, {!l 5}]
    -
      # IN predicate at snapshot isolation.
      - query: select id from t1 where id in (1, 3, 5) OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - unorderedResult: [{!l 1}, {!l 3}, {!l 5}]
    -
      # Join at snapshot isolation.
      - query: select t2.name from t1, t2 where t1.col1 = t2.id OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - unorderedResult: [{'ten'}, {'ten'}, {'ten'}, {'twenty'}, {'twenty'}]
    -
      # Combining with another query option.
      - query: select max_ever(col2) from t1 OPTIONS (ISOLATION LEVEL SNAPSHOT, LOG QUERY)
      - result: [{!l 8}]
---
test_block:
  name: snapshot-isolation-rejected-on-non-select
  tests:
    -
      # Snapshot isolation is not supported on INSERT.
      - query: insert into t1 values (100, 30, 30) OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - error: "0A000"
    -
      # Snapshot isolation is not supported on UPDATE.
      - query: update t1 set col2 = 99 where id = 1 OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - error: "0A000"
    -
      # Snapshot isolation is not supported on DELETE.
      - query: delete from t1 where id = 1 OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - error: "0A000"
    -
      # Snapshot isolation is not supported in a subquery
      - query: delete from t1 where id IN (select id from t1 where id = 1 OPTIONS (ISOLATION LEVEL SNAPSHOT))
      - error: "42601"
    -
      # Snapshot isolation is not supported in a subquery
      - query: insert into t2 (select id, 'name' from t1 where id = 1 OPTIONS (ISOLATION LEVEL SNAPSHOT))
      - error: "42601"
    -
      # Snapshot isolation is not supported in an index definition.
      - query: create schema template SNAPSHOT_TEMPLATE create table tt(id bigint, v bigint, primary key(id)) create index bad_idx as select v from tt OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - error: "42601"
    -
      # Snapshot isolation is not supported on a FROM subquery.
      - query: select id from (select id from t1 where id = 1 OPTIONS (ISOLATION LEVEL SNAPSHOT)) as sub
      - error: "42601"
    -
      # Snapshot isolation is not supported on a subquery in the WHERE clause (here an EXISTS subquery).
      - query: select id from t1 where exists (select id from t1 where id = 1 OPTIONS (ISOLATION LEVEL SNAPSHOT))
      - error: "42601"
...
