	unnamed-2═EXPLAIN SELECT "msgstate"."mboxRef"."string_value" as "mboxRefValue", "entry"."string_value" AS "category", "msgstate"."isDeleted", "msgstate"."groupKey", max("msgstate"."stateInternalDate") AS "maxDate" FROM "msgstate", (SELECT "key"."string_value" FROM "msgstate"."mboxRefUidMap") AS "entry" WHERE "msgstate"."___header"."zone_key" = 0 AND "msgstate"."___header"."tombstone" is not true AND "msgstate"."___header"."archived" is not true GROUP BY "msgstate"."___header"."zone_key", "msgstate"."mboxRef"."string_value", "entry"."string_value", "msgstate"."isDeleted", "msgstate"."groupKey"└ 
