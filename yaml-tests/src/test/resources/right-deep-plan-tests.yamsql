---
options:
    supported_version: !current_version
---
schema_template:
    create table t1(id bigint, name string, t2_refs bigint array, primary key(id))
    create table t2(id bigint, name string, primary key(id))
---
setup:
  steps:
    - query: INSERT INTO t2 VALUES (1000, 'B1'), (2000, 'B2'), (3000, 'B3')
    - query: INSERT INTO t1 VALUES (1, 'A1', [1000, 2000]), (2, 'A2', [2000]), (3, 'A3', [3000]), (4, 'A4', [1000])
---
test_block:
  name: array-join-default-planner
  tests:
    -
      - query: SELECT t1.name, t2.name
               FROM t1, t1.t2_refs AS ref
               JOIN t2 ON ref = t2.id
               WHERE t2.id IN (1000, 2000)
      - explain: "EXPLODE arrayDistinct(promote(@c30 AS ARRAY(LONG))) | FLATMAP q0 -> { SCAN(<,>) | TFILTER T2 | FILTER _.ID EQUALS q0 | FLATMAP q1 -> { SCAN(<,>) | TFILTER T1 | FLATMAP q2 -> { EXPLODE q2.T2_REFS | FILTER _ EQUALS q1.ID AS q3 RETURN q2 } AS q2 RETURN (q2 AS _0, q1 AS _1) } AS q5 RETURN (q5._0.NAME AS _0, q5._1.NAME AS _1) }"
      - unorderedResult: [
          {'A1', 'B1'},
          {'A1', 'B2'},
          {'A2', 'B2'},
          {'A4', 'B1'}]
---
# Same array join with PRODUCE_RIGHT_DEEP_PLANS_ONLY enabled.
test_block:
  name: array-join-right-deep-planner
  options:
    connection_options:
      PRODUCE_RIGHT_DEEP_PLANS_ONLY: true
  tests:
    -
      - query: SELECT t1.name, t2.name
               FROM t1, t1.t2_refs AS ref
               JOIN t2 ON ref = t2.id
               WHERE t2.id IN (1000, 2000)
      - explain: "EXPLODE arrayDistinct(promote(@c30 AS ARRAY(LONG))) | FLATMAP q0 -> { SCAN(<,>) | TFILTER T2 | FILTER _.ID EQUALS q0 | FLATMAP q1 -> { SCAN(<,>) | TFILTER T1 | FLATMAP q2 -> { EXPLODE q2.T2_REFS | FILTER _ EQUALS q1.ID AS q3 RETURN q2 } AS q2 RETURN (q2 AS _0, q1 AS _1) } AS q5 RETURN (q5._0.NAME AS _0, q5._1.NAME AS _1) }"
      - unorderedResult: [
          {'A1', 'B1'},
          {'A1', 'B2'},
          {'A2', 'B2'},
          {'A4', 'B1'}]
---
# Same array join with PRODUCE RIGHT DEEP PLANS ONLY set as a query-level option.
test_block:
  name: array-join-right-deep-query-option
  tests:
    -
      # Unnest t1.t2_refs and join to t2, with right-deep option in the query itself
      - query: SELECT t1.name, t2.name
               FROM t1, t1.t2_refs AS ref
               JOIN t2 ON ref = t2.id
               WHERE t2.id IN (1000, 2000)
               OPTIONS (PRODUCE RIGHT DEEP PLANS ONLY)
      - explain: "EXPLODE arrayDistinct(promote(@c30 AS ARRAY(LONG))) | FLATMAP q0 -> { SCAN(<,>) | TFILTER T2 | FILTER _.ID EQUALS q0 | FLATMAP q1 -> { SCAN(<,>) | TFILTER T1 | FLATMAP q2 -> { EXPLODE q2.T2_REFS | FILTER _ EQUALS q1.ID AS q3 RETURN q2 } AS q2 RETURN (q2 AS _0, q1 AS _1) } AS q5 RETURN (q5._0.NAME AS _0, q5._1.NAME AS _1) }"
      - unorderedResult: [
          {'A1', 'B1'},
          {'A1', 'B2'},
          {'A2', 'B2'},
          {'A4', 'B1'}]
...
