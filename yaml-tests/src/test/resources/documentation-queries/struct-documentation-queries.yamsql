---
schema_template:
  create type as struct single_field_st (f string)
  create type as struct multiple_field_st (a string, b string)
  create table foo (a string, b single_field_st, c multiple_field_st, primary key(a));
---
setup:
  steps:
    -
      - currentVersionLessThan: !current_version
        definition:
          - query: INSERT INTO foo VALUES ('Alice', ('foo'), ('1 First St', 'Springfield')),
                                          ('Bob', ('bar'), ('2 Second Ave', 'Shelbyville'))
      - currentVersionAtLeast: !current_version
        definition:
          - query: INSERT INTO foo VALUES ('Alice', STRUCT ('foo'), ('1 First St', 'Springfield')),
                                          ('Bob', STRUCT ('bar'), ('2 Second Ave', 'Shelbyville'))
---
test_block:
  name: struct-documentation-tests
  preset: single_repetition_ordered
  tests:
    # Construct an anonymous struct literal with two nested structs (documentation example)
    -
      - query: SELECT a, (b, c) FROM foo
      - result: [ {a: 'Alice', _1: { {f: 'foo'}, {a: '1 First St', b: 'Springfield'} } },
                  {a: 'Bob', _1: { {f: 'bar'}, {a: '2 Second Ave', b: 'Shelbyville'} } } ]

    # Same as the above, but with the optional STRUCT keyword included:
    -
      - query: SELECT a, STRUCT (b, c) FROM foo
      - supported_version: !current_version
      - result: [ {a: 'Alice', _1: { {f: 'foo'}, {a: '1 First St', b: 'Springfield'} } },
                  {a: 'Bob', _1: { {f: 'bar'}, {a: '2 Second Ave', b: 'Shelbyville'} } } ]

    # Construct an anonymous struct literal with a nested struct field
    -
      - query: SELECT a, STRUCT (c) FROM foo
      - supported_version: !current_version
      - result: [ { a: 'Alice', _1: { { a: '1 First St', b: 'Springfield' } } },
                  { a: 'Bob', _1: { { a: '2 Second Ave', b: 'Shelbyville' } } } ]

    # Construct a struct literal with named type with a nested struct field
    -
      - query: SELECT a, STRUCT namedType (b) FROM foo
      - result: [ {a: 'Alice', _1: { {f: 'foo'} } },
                  {a: 'Bob', _1: { {f: 'bar'} } } ]