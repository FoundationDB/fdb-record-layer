# YAMSQL cannot exercise
# true concurrency, so these verify that the option parses, plans, and executes without error and
# returns the correct results for a variety of query shapes, and that it is rejected on non-SELECT
# statements. The actual "no conflict range" behavior is verified in SnapshotIsolationConcurrencyTest.
---
options:
    supported_version: !current_version
---
schema_template:
    create table account(id bigint, balance bigint, primary key(id))
    create index max_balance_ever as select max_ever(balance) from account
---
setup:
  steps:
    - query: insert into account
            values (1, 100),
                   (2, 250),
                   (3, 175)
---
test_block:
  name: isolation-level-snapshot-tests
  preset: single_repetition_ordered
  tests:
    # Reading an aggregate at snapshot isolation.
    -
      - query: SELECT max_ever(balance) AS max_balance
              FROM account
              OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - result: [{max_balance: 250}]

    # A regular scan at snapshot isolation.
    -
      - query: SELECT id, balance
              FROM account
              WHERE id = 2
              OPTIONS (ISOLATION LEVEL SNAPSHOT)
      - result: [{id: 2, balance: 250}]
...
