---
schema_template:
    create type as struct ts(sa bigint, sb bigint)
    create type as struct fruit_type(name string, color string)
    create table ta(a bigint, b bigint, c double, d boolean, e string, f ts, primary key(a))
    create index f1 as select f.sa, f.sb from ta order by f.sa, f.sb
    create table array_table(id bigint, fruits string array, numbers bigint array, fruit_records fruit_type array, primary key(id))
    create index fruits as select fruits from array_table
    create table t_parent(id string, lst string array, primary key(id))
    create table t_child(id string, t_link fruit_type, num bigint, primary key(id))
    CREATE FUNCTION get_key(IN r TYPE fruit_type) RETURNS STRING AS r.name
---
test_block:
  tests:
    -
      # Test get_key() UDF on a struct column used as a join key, combined with
      # literal IN string-array and bigint IN value-list predicates.
      # c1 (num=1) and c2 (num=2) match; c3 excluded by num NOT IN (1,2,3);
      # c4 excluded because p2 lacks 'tag_a'; c5 excluded because p3 != 'p1'.
      - query: SELECT
                   t_child.id AS child_id,
                   t_child.num AS num,
                   t_parent.id AS parent_id
               FROM
                   t_parent,
                   t_child
               WHERE
                   get_key(t_child.t_link) = t_parent.id
                   AND 'tag_a' IN t_parent.lst
                   AND t_parent.id = 'p1'
                   AND t_child.num IN (1, 2, 3)
      - supported_version: !current_version
      - unorderedResult: [
          { child_id: 'c1', num: 1, parent_id: 'p1' },
          { child_id: 'c2', num: 2, parent_id: 'p1' }
        ]
...
