---
options:
    supported_version: 4.8.3.0
---
schema_template:
    create type as struct st1(y bigint, z bigint)
    create type as struct st2(w bigint, x bigint)
    create type as struct st3(u st2, v st1)
    create type as struct st4(s bigint, t bigint)
    create table nested(id bigint, q st4, r st3, primary key(q.s, r.u.w))
    create index i2 as select r.v.z from nested order by r.v.z
    create table simple_table(a bigint, b string, c integer, primary key(a))
    CREATE FUNCTION st2_func(IN x TYPE ST3) RETURNS ST2 AS x.u
    CREATE FUNCTION z(IN x TYPE ST3) RETURNS bigint AS x.v.z
    CREATE FUNCTION self(IN x bigint) RETURNS bigint AS x
    CREATE FUNCTION table_func1(IN limit_val bigint) AS SELECT id, self(id) as id_copy, z(r) as z_val FROM nested WHERE id <= limit_val
    CREATE FUNCTION table_func2(IN threshold bigint) AS SELECT self(id) as processed_id, z(r) as z_val FROM nested WHERE z(r) >= threshold
    CREATE FUNCTION table_func3(IN x bigint, IN y bigint) AS SELECT self(a) as a_val, self(a) as a_copy FROM simple_table WHERE a BETWEEN x AND y
    create type as struct line_item(price bigint, description string)
    create table order_t(id bigint, items line_item array, primary key(id))
    create table price_list(id bigint, list_price bigint, primary key(id))
    CREATE FUNCTION get_price(IN item TYPE line_item) RETURNS bigint AS item.price
    create type as struct level3(d bigint, extra bigint)
    create type as struct level2(c level3, extra bigint)
    create type as struct level1(b level2, extra bigint)
    create table deep_nested_t(id bigint, a level1, primary key(id))
    create index deep_idx as select a.b.c.d from deep_nested_t order by a.b.c.d
    CREATE FUNCTION abcd(IN a TYPE level1) RETURNS bigint AS a.b.c.d
---
setup:
  steps:
    - query: INSERT INTO NESTED
        VALUES (1, (200, 1), ((5, 11), (10, 100))),
               (2, (201, 2), ((5, 12), (10, 100))),
               (3, (202, 3), ((5, 13), (10, 100))),
               (4, (203, 4), ((5, 14), (10, 100))),
               (5, (329, 5), ((5, 15), (10, 140))),
               (6, (330, 6), ((5, 16), (10, 140)))
    - query: INSERT INTO simple_table
        VALUES (10, 'apple', 1),
               (20, 'banana', 2),
               (30, 'cherry', 3),
               (40, 'date', 4),
               (50, 'elderberry', 5)
    - query: INSERT INTO order_t
        VALUES (1, [(10, 'ten'), (20, 'twenty')]),
               (2, [(30, 'thirty'), (40, 'forty')])
    - query: INSERT INTO price_list
        VALUES (1, 20), (2, 30), (3, 99)
    - query: INSERT INTO deep_nested_t
        VALUES (1, (((10, 0), 0), 0)),
               (2, (((20, 0), 0), 0)),
               (3, (((30, 0), 0), 0)),
               (4, (((10, 0), 0), 0)),
               (5, (((50, 0), 0), 0))
---
test_block:
  name: user-defined-scalar-function-tests
  tests:
    -
      - query: select z(r) from nested group by z(r)
      - explain: "ISCAN(I2 <,>) | MAP (_ AS _0) | AGG () GROUP BY (_._0.R.V.Z AS _0) | MAP (_._0._0 AS _0)"
      - unorderedResult: [{100}, {140}]
    -
      - query: select st2_func(r) from nested
      - explain: "ISCAN(I2 <,>) | MAP (_.R.U AS _0)"
      - unorderedResult: [{{!l 5, !l 11}}, {{!l 5, !l 12}}, {{!l 5, !l 13}}, {{!l 5, !l 14}}, {{!l 5, !l 15}}, {{!l 5, !l 16}}]
    -
      - query: select id from nested where self(id) > 2 and self(id) < 5
      - explain: "ISCAN(I2 <,>) | FILTER _.ID GREATER_THAN promote(@c10 AS LONG) AND _.ID LESS_THAN promote(@c17 AS LONG) | MAP (_.ID AS ID)"
      - unorderedResult: [{3}, {4}]
    -
      # Test multiple invocations of same function in SELECT clause
      - query: select self(id) as A, self(id) as B, self(id * 2) as C from nested where id <= 2
      - explain: "ISCAN(I2 <,>) | FILTER _.ID LESS_THAN_OR_EQUALS promote(@c29 AS LONG) | MAP (_.ID AS A, _.ID AS B, _.ID * @c29 AS C)"
      - unorderedResult: [{A: 1, B: 1, C: 2}, {A: 2, B: 2, C: 4}]
    -
      # Test multiple invocations with different UDF functions
      - query: select z(r) as A, z(r) as B, st2_func(r) as C from nested where id = 1
      - explain: "ISCAN(I2 <,>) | FILTER _.ID EQUALS promote(@c26 AS LONG) | MAP (_.R.V.Z AS A, _.R.V.Z AS B, _.R.U AS C)"
      - unorderedResult: [{A: 100, B: 100, C: {!l 5, !l 11}}]
    -
      # Test multiple invocations in both SELECT and WHERE clauses
      - query: select self(id) as A, z(r) as B, z(r) as C from nested where z(r) = 100 and self(id) <= 3
      - explain: "ISCAN(I2 [EQUALS promote(@c29 AS LONG)]) | FILTER _.ID LESS_THAN_OR_EQUALS promote(@c37 AS LONG) | MAP (_.ID AS A, _.R.V.Z AS B, _.R.V.Z AS C)"
      - unorderedResult: [{A: 1, B: 100, C: 100}, {A: 2, B: 100, C: 100}, {A: 3, B: 100, C: 100}]
    -
      # Test table function with scalar UDF in SELECT and WHERE
      - query: select * from table_func1(3)
      - explain: "ISCAN(I2 <,>) | FILTER _.ID LESS_THAN_OR_EQUALS promote(@c5 AS LONG) | MAP (_.ID AS ID, _.ID AS ID_COPY, _.R.V.Z AS Z_VAL)"
      - unorderedResult: [{id: 1, id_copy: 1, z_val: 100}, {id: 2, id_copy: 2, z_val: 100}, {id: 3, id_copy: 3, z_val: 100}]
    -
      # Test table function with scalar UDF filtering
      - query: select * from table_func2(140)
      - explain: "ISCAN(I2 [[GREATER_THAN_OR_EQUALS promote(@c5 AS LONG)]]) | MAP (_.ID AS PROCESSED_ID, _.R.V.Z AS Z_VAL)"
      - unorderedResult: [{processed_id: 5, z_val: 140}, {processed_id: 6, z_val: 140}]
    -
      # Test table function with multiple scalar UDFs
      - query: select * from table_func3(20, 40)
      - explain: "SCAN([IS SIMPLE_TABLE, [GREATER_THAN_OR_EQUALS promote(@c5 AS LONG) && LESS_THAN_OR_EQUALS promote(@c7 AS LONG)]]) | MAP (_.A AS A_VAL, _.A AS A_COPY)"
      - unorderedResult: [{a_val: 20, a_copy: 20}, {a_val: 30, a_copy: 30}, {a_val: 40, a_copy: 40}]
    -
      # Test joining table function results with scalar UDF processing
      - query: select t1.id_copy as A, t2.processed_id as B from table_func1(2) t1, table_func2(100) t2 where t1.id_copy = t2.processed_id
      - explain: "ISCAN(I2 [[GREATER_THAN_OR_EQUALS promote(@c21 AS LONG)]]) | FLATMAP q0 -> { ISCAN(I2 <,>) | FILTER _.ID EQUALS q0.ID AND _.ID LESS_THAN_OR_EQUALS promote(@c15 AS LONG) AS q1 RETURN (q1.ID AS A, q0.ID AS B) }"
      - unorderedResult: [{A: 1, B: 1}, {A: 2, B: 2}]
    -
      # Test scalar UDF applied to table function results
      - query: select self(id_copy) as A, z_val as B from table_func1(4)
      - explain: "ISCAN(I2 <,>) | FILTER _.ID LESS_THAN_OR_EQUALS promote(@c14 AS LONG) | MAP (_.ID AS A, _.R.V.Z AS B)"
      - unorderedResult: [{A: 1, B: 100}, {A: 2, B: 100}, {A: 3, B: 100}, {A: 4, B: 100}]
    -
      # Test nested scalar UDF calls within table function results
      - query: select self(self(a_val)) as A, self(a_copy) as B from table_func3(10, 30)
      - explain: "SCAN([IS SIMPLE_TABLE, [GREATER_THAN_OR_EQUALS promote(@c20 AS LONG) && LESS_THAN_OR_EQUALS promote(@c22 AS LONG)]]) | MAP (_.A AS A, _.A AS B)"
      - unorderedResult: [{A: 10, B: 10}, {A: 20, B: 20}, {A: 30, B: 30}]
    -
      # Test table function with scalar UDF in WHERE clause filtering the result
      - query: select * from table_func1(6) where self(id_copy) > 3
      - explain: "ISCAN(I2 <,>) | FILTER _.ID LESS_THAN_OR_EQUALS promote(@c5 AS LONG) AND _.ID GREATER_THAN promote(@c13 AS LONG) | MAP (_.ID AS ID, _.ID AS ID_COPY, _.R.V.Z AS Z_VAL)"
      - unorderedResult: [{id: 4, id_copy: 4, z_val: 100}, {id: 5, id_copy: 5, z_val: 140}, {id: 6, id_copy: 6, z_val: 140}]
    -
      # Test UDF applied to unnested array-of-struct elements joined with another table.
      # order_t.items is an array of line_item structs; get_price(item) returns item.price.
      # The query unnests order_t.items as item and joins with price_list where
      # get_price(item) matches price_list.list_price.
      - query: select order_t.id as order_id, price_list.id as price_id, price_list.list_price, item.price, item.description from order_t, order_t.items as item, price_list where get_price(item) = price_list.list_price
      - supported_version: 4.10.10.0
      - unorderedResult: [{order_id: 1, price_id: 1, list_price: 20, price: 20, description: 'twenty'}, {order_id: 2, price_id: 2, list_price: 30, price: 30, description: 'thirty'}]
    -
      # Test deeply nested resolution a.b.c.d: select all ids with their deep field value
      - query: select id, abcd(a) as d_val from deep_nested_t
      - explain: "COVERING(DEEP_IDX <,> -> [ID: KEY:[2], A: [B: [C: [D: KEY:[0]]]]]) | MAP (_.ID AS ID, _.A.B.C.D AS D_VAL)"
      - unorderedResult: [{id: 1, d_val: 10}, {id: 2, d_val: 20}, {id: 3, d_val: 30}, {id: 4, d_val: 10}, {id: 5, d_val: 50}]
    -
      # Test deeply nested resolution a.b.c.d: group by the 4-level deep field, deduplicating values
      - query: select abcd(a) from deep_nested_t group by abcd(a)
      - explain: "ISCAN(DEEP_IDX <,>) | MAP (_ AS _0) | AGG () GROUP BY (_._0.A.B.C.D AS _0) | MAP (_._0._0 AS _0)"
      - unorderedResult: [{10}, {20}, {30}, {50}]
    -
      # Test deeply nested resolution a.b.c.d: range filter on the 4-level deep field
      - query: select id from deep_nested_t where abcd(a) > 20
      - unorderedResult: [{3}, {5}]
    -
      # Test deeply nested resolution a.b.c.d: exact equality filter on 4-level deep field
      - query: select id from deep_nested_t where abcd(a) = 10
      - unorderedResult: [{1}, {4}]
    -
      # Test deeply nested resolution a.b.c.d: compose with self (self wraps the 4-level result)
      - query: select self(abcd(a)) as d_val from deep_nested_t where abcd(a) <= 20
      - unorderedResult: [{d_val: 10}, {d_val: 20}, {d_val: 10}]
    -
      # direct field access on unnested struct array via AS alias.
      # Both item.price and item.description are resolved directly from the output of
      # generateCorrelatedFieldAccess (EphemeralExpression(item) + ITEM.PRICE + ITEM.DESCRIPTION).
      - query: select item.price, item.description from order_t, order_t.items as item
      - supported_version: 4.10.10.0
      - unorderedResult: [{10, 'ten'}, {20, 'twenty'}, {30, 'thirty'}, {40, 'forty'}]
    -
      # direct field access with a filter on the unnested struct field.
      - query: select order_t.id, item.price from order_t, order_t.items as item where item.price >= 20
      - supported_version: 4.10.10.0
      - unorderedResult: [{1, 20}, {2, 30}, {2, 40}]
    -
      # subquery that projects the whole struct element; outer query accesses a field.
      # The inner query selects item (EphemeralExpression) and the outer resolves item.price via
      # lookupNestedField on the EphemeralExpression after clearQualifier().
      - query: select item.price from (select item from order_t, order_t.items as item) as a
      - supported_version: 4.10.10.0
      - unorderedResult: [{10}, {20}, {30}, {40}]
    -
      # same subquery pattern, accessing both fields and filtering on one of them.
      - query: select item.price, item.description from (select item from order_t, order_t.items as item) as a where item.price < 25
      - supported_version: 4.10.10.0
      - unorderedResult: [{10, 'ten'}, {20, 'twenty'}]
    -
      # UDF receiving the whole struct element (EphemeralExpression exact-match).
      # get_price(item) is resolved by matching the unqualified name 'item' to EphemeralExpression(ITEM).
      - query: select get_price(item) as p from order_t, order_t.items as item
      - supported_version: 4.10.10.0
      - unorderedResult: [{10}, {20}, {30}, {40}]
    -
      # UDF whole-struct result alongside direct field access — both must resolve
      # without ambiguity (EphemeralExpression-derived ITEM.PRICE deduped against direct ITEM.PRICE).
      - query: select item.price as direct, get_price(item) as via_udf from order_t, order_t.items as item
      - supported_version: 4.10.10.0
      - unorderedResult: [{direct: 10, via_udf: 10}, {direct: 20, via_udf: 20}, {direct: 30, via_udf: 30}, {direct: 40, via_udf: 40}]
    -
      # wrong function name
      - query: select zz(r) from nested group by z(r)
      - error: UNSUPPORTED_QUERY
    -
      - query: select z(((1l, 2l), (3l, 4l))) from range(1, 2)
      - initialVersionLessThan: !current_version
      - error: INVALID_ARGUMENT_FOR_FUNCTION
      - initialVersionAtLeast: !current_version
      - unorderedResult: [{!l 4}]
---
setup:
  connect: "jdbc:embed:/__SYS?schema=CATALOG"
  options:
    supported_version: !current_version
  steps:
    - query: drop schema template if exists test_user_defined_macro_functoins_with_expressions
    - query: create schema template test_user_defined_macro_functoins_with_expressions
             create type as struct st1(y bigint, z bigint)
             create type as struct st2(w bigint, x bigint)
             create type as struct st3(u st2, v st1)
             create table nested(id bigint, r st3, primary key(id))
             create function add_udf(in a bigint, in b bigint) returns bigint return a + b 
             create function st1_constructor(in a bigint) returns st1 return (a, 0L)
             create function st1_constructor_alt(in a bigint) returns st1 as (a, 5L)
             create function z(in x type st3) returns bigint return x.v.z
             create function z_alt(in x type st3) returns bigint as x.v.z
             create function st1_array(in a type st1) RETURNS st1 array as [a]
             create function st1_array_alt(in a type st1) RETURNS st1 array return [a]
             create function st1_array_without_return_type(in a type st1) return [a]
             create function st1_array_first(in a type st1 array) returns st1 return a[1]
             create function st1_constructor_with_defaults(in y bigint, in z bigint default 2L) returns st1 return (y, z)
             create function zero() returns bigint return 0l
    - query: drop database if exists /FRL/MACRO_WITH_EXPRESSIONS
    - query: create database /FRL/MACRO_WITH_EXPRESSIONS
    - query: create schema /FRL/MACRO_WITH_EXPRESSIONS/test with template test_user_defined_macro_functoins_with_expressions
---
setup:
  connect: "jdbc:embed:/FRL/MACRO_WITH_EXPRESSIONS?schema=TEST"
  options:
    supported_version: !current_version
  steps:
    - query: INSERT INTO NESTED
        VALUES (1, ((5, 11), (10, 100))),
               (2, ((5, 12), (10, 100))),
               (3, ((5, 13), (10, 100))),
               (4, ((5, 14), (10, 100))),
               (5, ((5, 15), (10, 140))),
               (6, ((5, 16), (10, 140)))
---
test_block:
  name: user-defined-scalar-function-with-expressions-tests
  connect: "jdbc:embed:/FRL/MACRO_WITH_EXPRESSIONS?schema=TEST"
  options:
    supported_version: !current_version
  tests:
    -
      - query: select add_udf(0, 1l) from range(1, 2)
      - explain: "TF range(promote(@c10 AS LONG), promote(@c12 AS LONG), STEP 1l) | MAP (promote(@c3 AS LONG) + @c5 AS _0)"
      - unorderedResult: [{ !l 1 }]
    -
      - query: select add_udf(5l, 10l) from range(1, 2)
      - explain: "TF range(promote(@c10 AS LONG), promote(@c12 AS LONG), STEP 1l) | MAP (@c3 + @c5 AS _0)"
      - unorderedResult: [{ !l 15 }]
    -
      - query: select st1_constructor(r.u.x) from nested
      - explain: "SCAN([IS NESTED]) | MAP (promote((_.R.U.X AS A, 0l AS _1) AS LONG AS Y, LONG AS Z) AS _0)"
      - unorderedResult: [{ {!l 11, !l 0} },
                          { {!l 12, !l 0} },
                          { {!l 13, !l 0} },
                          { {!l 14, !l 0} },
                          { {!l 15, !l 0} },
                          { {!l 16, !l 0} }]
    -
      - query: select st1_constructor_alt(r.u.x) from nested
      - explain: "SCAN([IS NESTED]) | MAP (promote((_.R.U.X AS A, 5l AS _1) AS LONG AS Y, LONG AS Z) AS _0)"
      - unorderedResult: [{ {!l 11, !l 5} },
                          { {!l 12, !l 5} },
                          { {!l 13, !l 5} },
                          { {!l 14, !l 5} },
                          { {!l 15, !l 5} },
                          { {!l 16, !l 5} }]
    -
      - query: select z(r) from nested
      - explain: "SCAN([IS NESTED]) | MAP (_.R.V.Z AS _0)"
      - unorderedResult: [{100}, {100}, {100}, {100}, {140}, {140}]
    -
      - query: select z_alt(r) from nested
      - explain: "SCAN([IS NESTED]) | MAP (_.R.V.Z AS _0)"
      - unorderedResult: [{100}, {100}, {100}, {100}, {140}, {140}]
    -
      - query: select st1_array((1l, 2l)) from range(1, 2)
      - explain: "TF range(promote(@c12 AS LONG), promote(@c14 AS LONG), STEP 1l) | MAP (array(promote((@c4 AS _0, @c6 AS _1) AS LONG AS Y, LONG AS Z)) AS _0)"
      # TODO: disable forceContinuation until https://github.com/FoundationDB/fdb-record-layer/pull/4171 is merged.
      - maxRows: 0
      - unorderedResult: [{ [ {!l 1, !l 2} ]} ]
    -
      - query: select st1_array_alt(r.v) from nested
      - explain: "SCAN([IS NESTED]) | MAP (array(_.R.V) AS _0)"
      # TODO: disable forceContinuation until https://github.com/FoundationDB/fdb-record-layer/pull/4171 is merged.
      - maxRows: 0
      - unorderedResult: [{ [ {y: !l 10, z: !l 100} ]},
                          { [ {y: !l 10, z: !l 100} ]},
                          { [ {y: !l 10, z: !l 100} ]},
                          { [ {y: !l 10, z: !l 100} ]},
                          { [ {y: !l 10, z: !l 140} ]},
                          { [ {y: !l 10, z: !l 140} ]}]
    -
      - query: select st1_array_without_return_type(r.v) from nested
      - explain: "SCAN([IS NESTED]) | MAP (array(_.R.V) AS _0)"
      # TODO: disable forceContinuation until https://github.com/FoundationDB/fdb-record-layer/pull/4171 is merged.
      - maxRows: 0
      - unorderedResult: [{ [ {y: !l 10, z: !l 100} ]},
                          { [ {y: !l 10, z: !l 100} ]},
                          { [ {y: !l 10, z: !l 100} ]},
                          { [ {y: !l 10, z: !l 100} ]},
                          { [ {y: !l 10, z: !l 140} ]},
                          { [ {y: !l 10, z: !l 140} ]}]
    -
      - query: select st1_array((0l, 1l))[1] from range(1, 2)
      - explain: "TF range(promote(@c15 AS LONG), promote(@c17 AS LONG), STEP 1l) | MAP (array(promote((@c4 AS _0, @c6 AS _1) AS LONG AS Y, LONG AS Z))[promote(@c15 AS INT)] AS _0)"
      - unorderedResult: [{ {y: !l 0, z: !l 1} }]
    -
      # TODO: this should be fixed as part of https://github.com/FoundationDB/fdb-record-layer/issues/4177
      - query: select temp_z(r) from nested
      - setup: create temporary function temp_z(IN r TYPE st3) returns bigint on commit drop function return r.v.z
      - error: INTERNAL_ERROR
    -
      # TODO: this should be fixed as part of https://github.com/FoundationDB/fdb-record-layer/issues/4317
      - query: select temp_constructor(r.u.w) from nested where id = 1
      - setup: create temporary function temp_constructor(IN x bigint) returns st1 on commit drop function return (x, 5L)
      - error: UNKNOWN_TYPE
    -
      - query: select temp_constructor(r.u.w) from nested where id = 1
      - setup: create temporary function temp_constructor(IN x bigint) on commit drop function return (x, 5L)
      - explain: "SCAN([IS NESTED, EQUALS promote(@c14 AS LONG)]) | MAP ((_.R.U.W AS X, 5l AS _1) AS _0)"
      - unorderedResult: [{ {x: 5, !pos 2: 5} }]
    -
      - query: select st1_constructor_with_defaults(4) from range(1, 2)
      - explain: "TF range(promote(@c8 AS LONG), promote(@c10 AS LONG), STEP 1l) | MAP ((promote(@c3 AS LONG) AS Y, promote(2l AS LONG) AS Z) AS _0)"
      - unorderedResult: [{ {y: 4, z: 2} }]
    -
      - query: select st1_constructor_with_defaults((3*2)) from range(1, 2)
      - explain: "TF range(promote(@c12 AS LONG), promote(@c14 AS LONG), STEP 1l) | MAP ((promote(@c4 * @c14 AS LONG) AS Y, promote(2l AS LONG) AS Z) AS _0)"
      - unorderedResult: [{ {y: 6, z: 2} }]
    -
      - query: select st1_constructor_with_defaults(4, 5) from range(1, 2)
      - explain: "TF range(promote(@c10 AS LONG), promote(@c12 AS LONG), STEP 1l) | MAP ((promote(@c3 AS LONG) AS Y, promote(@c5 AS LONG) AS Z) AS _0)"
      - unorderedResult: [{ {y: 4, z: 5} }]
    -
      - query: select st1_constructor_with_defaults(y => 4) from range(1, 2)
      - explain: "TF range(promote(@c10 AS LONG), promote(@c12 AS LONG), STEP 1l) | MAP ((promote(@c5 AS LONG) AS Y, promote(2l AS LONG) AS Z) AS _0)"
      - unorderedResult: [{ {y: 4, z: 2} }]
    -
      - query: select st1_constructor(5l) from range(1, 2)
      - explain: "TF range(promote(@c8 AS LONG), promote(@c10 AS LONG), STEP 1l) | MAP (promote((@c3 AS A, 0l AS _1) AS LONG AS Y, LONG AS Z) AS _0)"
      - unorderedResult: [{ { Y: !l 5, Z: !l 0 } }]
    -
      - query: select zero() from range(1, 2)
      - unorderedResult: [{ !l 0 }]
    -
      - query: select st1_constructor_with_defaults(z => 5) from range(1, 2)
      - error: UNDEFINED_FUNCTION
    -
      - query: select st1_constructor_with_defaults() from range(1, 2)
      - error: UNDEFINED_FUNCTION
    -
      - query: select st1_constructor(2.0) from range(1, 2)
      - error: INVALID_ARGUMENT_FOR_FUNCTION
    -
      - query: select st1_constructor('2') from range(1, 2)
      - error: INVALID_ARGUMENT_FOR_FUNCTION
    -
      - query: select st1_constructor_with_defaults from range(1, 2)
      - error: UNDEFINED_COLUMN
---
setup:
  connect: "jdbc:embed:/__SYS?schema=CATALOG"
  options:
    supported_version: !current_version
