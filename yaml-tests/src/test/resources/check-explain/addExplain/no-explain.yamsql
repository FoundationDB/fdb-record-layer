# Used by CheckExplainTest.addExplainPopulatesMissingExplain.
# The query intentionally has no explain: block. When run with OPTION_ADD_EXPLAIN,
# the actual plan is inserted before the result: line. On subsequent runs the
# file is stable (the inserted plan matches the actual plan).
---
schema_template:
    create table t1(id bigint, primary key(id))
---
setup:
  steps:
    - query: INSERT INTO t1 VALUES (1)
---
test_block:
  tests:
    -
      - query: SELECT id FROM t1
      - explain: "SCAN([IS T1])"
      - result: [{!l 1}]
...
