                   {b: "bar", c: 0, d: 1, e: "e1", _4: 11},
                   {b: "bar", c: 0, d: 1, e: "e2", _4: 11},
                ]
    -
      - query: select b, c, d, e, min(x) from t5 where a = 0 group by a, b, c, d, e having b IN ('foo', 'bar') and d IN (1, 2) order by min(x), c, e
      - explain: "[IN arrayDistinct(@c33)] INUNION q0 -> { [IN arrayDistinct(promote(@c41 AS ARRAY(LONG)))] INUNION q1 -> { AISCAN(MV17 [EQUALS promote(@c18 AS LONG), EQUALS q0] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[4], _4: KEY:[5], _5: KEY:[2]]) | FILTER _._3 EQUALS q1 | MAP (_._1 AS B, _._2 AS C, _._3 AS D, _._4 AS E, _._5 AS _4) } COMPARE BY (_._4, _.C, _.E, _.D) } COMPARE BY (_._4, _.C, _.E, _.B)"
      - initialVersionLessThan: 4.3.5.0
      - error: "0AF00"
      - initialVersionAtLeast: 4.3.5.0
      - resultMetadata: [{B: STRING}, {C: BIGINT}, {D: BIGINT}, {E: STRING}, {_4: BIGINT}]
      - result: [
                   {b: "bar", c: 0, d: 1, e: "e1", _4:  0},
                   {b: "bar", c: 0, d: 1, e: "e2", _4:  0},
                   {b: "foo", c: 0, d: 1, e: "e1", _4:  1},
                   {b: "foo", c: 0, d: 1, e: "e2", _4:  1},
                   {b: "foo", c: 0, d: 2, e: "e1", _4:  2},
                   {b: "foo", c: 3, d: 2, e: "e2", _4:  2},
                   {b: "foo", c: 0, d: 2, e: "e2", _4:  3},
                   {b: "foo", c: 3, d: 1, e: "e1", _4:  3},
                ]
    -
      - query: select b, c, d, e, max(x) from t5 where a = 0 and c = 0 group by a, b, c, d, e having b IN ('foo', 'bar') order by max(x), d
      - explain: "[IN arrayDistinct(@c37)] INUNION q0 -> { AISCAN(MV18 [EQUALS promote(@c18 AS LONG), EQUALS q0, EQUALS promote(@c18 AS LONG)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[2], _3: KEY:[4], _4: KEY:[5], _5: KEY:[3]]) | MAP (_._1 AS B, _._2 AS C, _._3 AS D, _._4 AS E, _._5 AS _4) } COMPARE BY (_._4, _.D, _.B, _.C, _.E)"
      - resultMetadata: [{B: STRING}, {C: BIGINT}, {D: BIGINT}, {E: STRING}, {_4: BIGINT}]
      - result: [
                   {b: "foo", c: 0, d: 2, e: "e2", _4:  8},
                   {b: "foo", c: 0, d: 2, e: "e1", _4:  9},
                   {b: "foo", c: 0, d: 1, e: "e1", _4: 10},
                   {b: "foo", c: 0, d: 1, e: "e2", _4: 10},
                   {b: "bar", c: 0, d: 1, e: "e1", _4: 11},
                   {b: "bar", c: 0, d: 1, e: "e2", _4: 11},
                ]
    -
      - query: select b, c, d, e, min(x) from t5 where a = 0 and c = 0 group by a, b, c, d, e having b IN ('foo', 'bar') order by min(x), d
      - explain: "[IN arrayDistinct(@c37)] INUNION q0 -> { AISCAN(MV19 [EQUALS promote(@c18 AS LONG), EQUALS q0, EQUALS promote(@c18 AS LONG)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[2], _3: KEY:[4], _4: KEY:[5], _5: KEY:[3]]) | MAP (_._1 AS B, _._2 AS C, _._3 AS D, _._4 AS E, _._5 AS _4) } COMPARE BY (_._4, _.D, _.B, _.C, _.E)"
      - resultMetadata: [{B: STRING}, {C: BIGINT}, {D: BIGINT}, {E: STRING}, {_4: BIGINT}]
      - result: [
                   {b: "bar", c: 0, d: 1, e: "e1", _4:  0},
                   {b: "bar", c: 0, d: 1, e: "e2", _4:  0},
                   {b: "foo", c: 0, d: 1, e: "e1", _4:  1},
                   {b: "foo", c: 0, d: 1, e: "e2", _4:  1},
                   {b: "foo", c: 0, d: 2, e: "e1", _4:  2},
                   {b: "foo", c: 0, d: 2, e: "e2", _4:  3},
                ]
    -
      - query: select sum(col3) from T2 group by col2
      - explain: "AISCAN(MV21 <,> BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[2], _3: VALUE:[0]]) | AGG sum_l(_._3) GROUP BY (_._0 AS _0) | MAP (_._3 AS _0)"
      - result: [{!l 1504}, {!l 202}]
    -
      # The aggregate index MV21 can't be used as the query's grouping value is not a prefix of the index grouping values.
      - query: select sum(col3) from T2 group by col1
      - explain: "ISCAN(MV3 <,>) | MAP (_ AS _0) | AGG (sum_l(_._0.COL3) AS _0) GROUP BY (_._0.COL1 AS _0) | MAP (_._1._0 AS _0)"
      - initialVersionLessThan: !current_version
      - unorderedResult: [{!l 1504}, {!l 202}]
      - initialVersionAtLeast: !current_version
      - unorderedResult: [{!l 1403}, {!l 303}]
    -
       # The aggregate index MV21 can be used here as the set of the query's grouping values are subsumed by a prefix
       # of the index grouping values.
      - query: select col1, col2, sum(col3) as s from T2 group by col1, col2
      - explain: "AISCAN(MV21 <,> BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[2], _3: VALUE:[0]]) | AGG sum_l(_._3) GROUP BY (_._0 AS _0, _._1 AS _1) | MAP (_._1 AS COL1, _._0 AS COL2, _._3 AS S)"
      - unorderedResult: [{col1: 1, col2: 1, s: 101},
                          {col1: 1, col2: 2, s: 202},
                          {col1: 2, col2: 1, s: 1403}]
    -
      # The aggregate index MV21 can be used here as the set of the query's grouping values (along with the implied
      # grouping due to the equality predicate) are subsumed by a prefix of the index grouping values.
      - query: select col1, sum(col3) as s from T2 where col2 = 2 group by col1
      - explain: "AISCAN(MV21 [EQUALS promote(@c14 AS LONG)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[2], _3: VALUE:[0]]) | AGG sum_l(_._3) GROUP BY (_._0 AS _0, _._1 AS _1) | MAP (_._1 AS COL1, _._3 AS S)"
      - unorderedResult: [{col1: 1, s: 202}]
    -
      # TODO: It should have been possible to use the aggregate index MV21 here as the query's grouping value is a prefix
      #       of the index grouping values, however the planner doesn't support applying a predicate compensation before
      #       applying a roll-up, which will be tackled as part of https://github.com/FoundationDB/fdb-record-layer/issues/4115.
      - query: select col2, sum(col3) as s from T2 where col3 = 200 group by col2
      - explain: "ISCAN(VI2 <,>) | FILTER _.COL3 EQUALS promote(@c14 AS LONG) | MAP (_ AS _0) | AGG (sum_l(_._0.COL3) AS _0) GROUP BY (_._0.COL2 AS _0) | MAP (_._0._0 AS COL2, _._1._0 AS S)"
      - unorderedResult: [ { col2: 1, s: 200 }, { col2: 2, s: 200 } ]
    -
      # The aggregate index MV21 can't be used here as the query's requested ordering is not compatible with the
      # index's ordering.
      - query: select col1, col2, sum(col3) as s from T2 group by col1, col2 order by col1, col2
      - explain: "ISCAN(MV2 <,>) | MAP (_ AS _0) | AGG (sum_l(_._0.COL3) AS _0) GROUP BY (_._0.COL1 AS _0, _._0.COL2 AS _1) | MAP (_._0._0 AS COL1, _._0._1 AS COL2, _._1._0 AS S)"
      - unorderedResult: [{col1: 1, col2: 1, s: 101},
                          {col1: 1, col2: 2, s: 202},
                          {col1: 2, col2: 1, s: 1403}]
    -
      - query: select sum(col3) from T2;
      - explain: "AISCAN(MV21 <,> BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[2], _3: VALUE:[0]]) | AGG sum_l(_._3) GROUP BY () | MAP ((_._3 AS _0) AS _0) | ON EMPTY NULL | MAP (_._0._0 AS _0)"
      - result: [{!l 1706}]
    -
      # Permuted max index with fan-out grouping element over nested repeated field (t6/mv20)
      - query: select a, ek.k, b, max(d) from t6, (select k from t6.c) as ek group by a, ek.k, b
      - explain: "AISCAN(MV20 <,> BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._0 AS A, _._1 AS K, _._2 AS B, _._3 AS _3)"
      - result: [{a: 1, k: 'p', b: 10, _3: 150},
                 {a: 1, k: 'q', b: 10, _3: 150},
                 {a: 1, k: 'r', b: 10, _3: 100},
                 {a: 2, k: 'p', b: 10, _3:  50},
                 {a: 2, k: 'q', b: 10, _3:  50},
                 {a: 2, k: 'q', b: 20, _3: 400},
                 {a: 2, k: 'r', b: 20, _3: 400}]
    -
      # Filter on a uses the leading key of the permuted max index
      - query: select ek.k, b, max(d) from t6, (select k from t6.c) as ek where a = 1 group by a, ek.k, b
      - explain: "AISCAN(MV20 [EQUALS promote(@c27 AS LONG)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._1 AS K, _._2 AS B, _._3 AS _2)"
      - result: [{k: 'p', b: 10, _2: 150},
                 {k: 'q', b: 10, _2: 150},
                 {k: 'r', b: 10, _2: 100}]
    -
      - query: select ek.k, b, max(d) from t6, (select k from t6.c) as ek where a = 2 group by ek.k, b
      - explain: "AISCAN(MV20 [EQUALS promote(@c27 AS LONG)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._1 AS K, _._2 AS B, _._3 AS _2)"
      - result: [{k: 'p', b: 10, _2:  50},
                 {k: 'q', b: 10, _2:  50},
                 {k: 'q', b: 20, _2: 400},
                 {k: 'r', b: 20, _2: 400}]
    -
      - query: select ek.k, b, max(d) from t6, (select k from t6.c where k = 'q') as ek where a = 2 group by a, ek.k, b
      - explain: "AISCAN(MV20 [EQUALS promote(@c31 AS LONG), EQUALS promote(@c24 AS STRING)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._1 AS K, _._2 AS B, _._3 AS _2)"
      - result: [{k: 'q', b: 10, _2:  50},
                 {k: 'q', b: 20, _2: 400}]
    -
      - query: select b, max(d) from t6, (select k from t6.c where k = 'q') as ek where a = 2 group by b
      - explain: "AISCAN(MV20 [EQUALS promote(@c27 AS LONG), EQUALS promote(@c20 AS STRING)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._2 AS B, _._3 AS _1)"
      - result: [{b: 10, _1:  50},
                  {b: 20, _1: 400}]
    -
      - query: select b, max(d) from t6, (select k from t6.c where k = 'q') as ek where a = 2 group by b order by max(d)
      - explain: "AISCAN(MV20 [EQUALS promote(@c27 AS LONG), EQUALS promote(@c20 AS STRING)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._2 AS B, _._3 AS _1)"
      - result: [{b: 10, _1:  50},
                  {b: 20, _1: 400}]
    -
      - query: select b, max(d) from t6, (select k from t6.c where k = 'q') as ek where a = 2 group by b order by max(d) desc
      - explain: "AISCAN(MV20 [EQUALS promote(@c27 AS LONG), EQUALS promote(@c20 AS STRING)] BY_GROUP REVERSE -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._2 AS B, _._3 AS _1)"
      - result: [{b: 20, _1: 400},
                  {b: 10, _1:  50}]
    -
      # HAVING on the aggregate — keep only groups where max(d) > 100
      - query: select a, ek.k, b, max(d) from t6, (select k from t6.c) as ek group by a, ek.k, b having max(d) > 100
      - explain: "AISCAN(MV20 <,> BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | FILTER _._3 GREATER_THAN promote(@c41 AS LONG) | MAP (_._0 AS A, _._1 AS K, _._2 AS B, _._3 AS _3)"
      - result: [{a: 1, k: 'p', b: 10, _3: 150},
                 {a: 1, k: 'q', b: 10, _3: 150},
                 {a: 2, k: 'q', b: 20, _3: 400},
                 {a: 2, k: 'r', b: 20, _3: 400}]
    -
      # WHERE on outer + HAVING on aggregate
      - query: select ek.k, b, max(d) from t6, (select k from t6.c) as ek where a = 1 group by a, ek.k, b having max(d) >= 150
      - explain: "AISCAN(MV20 [EQUALS promote(@c27 AS LONG)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | FILTER _._3 GREATER_THAN_OR_EQUALS promote(@c44 AS LONG) | MAP (_._1 AS K, _._2 AS B, _._3 AS _2)"
      - result: [{k: 'p', b: 10, _2: 150},
                 {k: 'q', b: 10, _2: 150}]
    -
      # Inner select predicate + HAVING
      - query: select a, ek.k, b, max(d) from t6, (select k from t6.c where k = 'q') as ek group by a, ek.k, b having a = 1 and max(d) > 100
      - explain: "AISCAN(MV20 [EQUALS promote(@c42 AS LONG), EQUALS promote(@c26 AS STRING), [GREATER_THAN promote(@c49 AS LONG)]] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._0 AS A, _._1 AS K, _._2 AS B, _._3 AS _3)"
      - result: [{a: 1, k: 'q', b: 10, _3: 150}]
---
transaction_setups:
  t6_all: create temporary function "t6v" () on commit drop function AS
    SELECT * FROM t6
  t6_a1: create temporary function "t6v" () on commit drop function AS
    SELECT * FROM t6 WHERE a = 1
  t6_a2: create temporary function "t6v" () on commit drop function AS
    SELECT * FROM t6 WHERE a = 2
---
test_block:
  name: agg-index-tests-t6-tvf
  options:
    connection_lifecycle: test
    supported_version: 4.10.20.0
  tests:
    -
      # Full scan via TVF with no predicate
      - query: select a, ek.k, b, max(d) from "t6v", (select k from "t6v".c) as ek group by a, ek.k, b
      - setupReference: t6_all
      - explain: "AISCAN(MV20 <,> BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._0 AS A, _._1 AS K, _._2 AS B, _._3 AS _3)"
      - result: [{a: 1, k: 'p', b: 10, _3: 150},
                 {a: 1, k: 'q', b: 10, _3: 150},
                 {a: 1, k: 'r', b: 10, _3: 100},
                 {a: 2, k: 'p', b: 10, _3:  50},
                 {a: 2, k: 'q', b: 10, _3:  50},
                 {a: 2, k: 'q', b: 20, _3: 400},
                 {a: 2, k: 'r', b: 20, _3: 400}]
    -
      # TVF pre-filters to a=1, no WHERE in query
      - query: select ek.k, b, max(d) from "t6v", (select k from "t6v".c) as ek group by ek.k, b
      - setupReference: t6_a1
      - explain: "AISCAN(MV20 [EQUALS promote(@ct6v18 AS LONG)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._1 AS K, _._2 AS B, _._3 AS _2)"
      - result: [{k: 'p', b: 10, _2: 150},
                 {k: 'q', b: 10, _2: 150},
                 {k: 'r', b: 10, _2: 100}]
    -
      # TVF pre-filters to a=2, no WHERE in query
      - query: select ek.k, b, max(d) from "t6v", (select k from "t6v".c) as ek group by ek.k, b
      - setupReference: t6_a2
      - explain: "AISCAN(MV20 [EQUALS promote(@ct6v18 AS LONG)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._1 AS K, _._2 AS B, _._3 AS _2)"
      - result: [{k: 'p', b: 10, _2:  50},
                 {k: 'q', b: 10, _2:  50},
                 {k: 'q', b: 20, _2: 400},
                 {k: 'r', b: 20, _2: 400}]
    -
      # Inner select predicate via Temp function
      - query: select ek.k, b, max(d) from "t6v", (select k from "t6v".c where k = 'q') as ek group by ek.k, b
      - setupReference: t6_a2
      - explain: "AISCAN(MV20 [EQUALS promote(@ct6v18 AS LONG), EQUALS promote(@c24 AS STRING)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._1 AS K, _._2 AS B, _._3 AS _2)"
      - result: [{k: 'q', b: 10, _2:  50},
                 {k: 'q', b: 20, _2: 400}]
    -
      # Temp function pre-filters a=1, HAVING on aggregate
      - query: select ek.k, b, max(d) from "t6v", (select k from "t6v".c) as ek group by ek.k, b having max(d) >= 150
      - setupReference: t6_a1
      - explain: "AISCAN(MV20 [EQUALS promote(@ct6v18 AS LONG)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | FILTER _._3 GREATER_THAN_OR_EQUALS promote(@c38 AS LONG) | MAP (_._1 AS K, _._2 AS B, _._3 AS _2)"
      - result: [{k: 'p', b: 10, _2: 150},
                 {k: 'q', b: 10, _2: 150}]
    -
      # Temp function no predicate, inner select predicate + HAVING
      - query: select a, ek.k, b, max(d) from "t6v", (select k from "t6v".c where k = 'q') as ek group by a, ek.k, b having max(d) > 100
      - setupReference: t6_a2
      - explain: "AISCAN(MV20 [EQUALS promote(@ct6v18 AS LONG), EQUALS promote(@c26 AS STRING), [GREATER_THAN promote(@c45 AS LONG)]] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[3], _3: KEY:[2]]) | MAP (_._0 AS A, _._1 AS K, _._2 AS B, _._3 AS _3)"
      - result: [{a: 2, k: 'q', b: 20, _3: 400}]
...
