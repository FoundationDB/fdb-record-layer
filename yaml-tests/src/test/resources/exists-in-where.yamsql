---
schema_template:
    create table array_table(id bigint, fruits string array, numbers bigint array, primary key(id))
    create index fruits as select fruits from array_table
---
setup:
  steps:
    - query: INSERT INTO array_table
        VALUES (1, ['apple', 'banana', 'cherry'], [10, 20, 30]),
               (2, ['grape', 'orange'], [40, 50]),
               (3, ['apple', 'grape', 'mango'], [10, 60, 70]),
               (4, ['kiwi'], [80]),
               (5, ['banana', 'cherry', 'date'], [20, 90, 100])
---
test_block:
  name: exists-in-where
  tests:
    -
      # Test alternate IN-like predicate with primitive array column - string in string array
      - query: select id from array_table where exists (select 1 from array_table.fruits f where f = 'apple')
      - explain: "COVERING(FRUITS [EQUALS @c17] -> [ID: KEY:[2]]) | MAP (_.ID AS ID)"
      - unorderedResult: [{1}, {3}]
#    -
#      # Test EXISTS with partial index coverage - index handles array iteration but
#      # predicate requires additional compensation (Case B: partial match)
#      - query: select id from array_table where exists (select 1 from array_table.fruits f where f = 'apple') and exists (select 1 from array_table.numbers n where n > 50)
#      - explain: "ISCAN(FRUITS [EQUALS @c17]) | FLATMAP q0 -> { EXPLODE q0.NUMBERS | FILTER _ GREATER_THAN promote(@c32 AS LONG) | MAP (@c8 AS _0) | DEFAULT NULL | FILTER _ NOT_NULL AS q1 RETURN (q0.ID AS ID) }"
#      - unorderedResult: [{3}]
