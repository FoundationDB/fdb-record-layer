!°f °į½┌/ éµµ“(ī0“·╠Ė8┴@╦ņEXPLODE arrayDistinct(promote(@c40 AS ARRAY(LONG))) | FLATMAP q0 -> { SCAN(<,>) | TFILTER DEPT | FILTER _.ID EQUALS q0 | FLATMAP q1 -> { SCAN(<,>) | TFILTER EMP | FILTER _.DEPT_ID EQUALS q1.ID | FLATMAP q2 -> { SCAN(<,>) | TFILTER PROJECT | FILTER _.EMP_ID EQUALS q2.ID AS q3 RETURN q3 } AS q3 RETURN (q1.ID AS ID, q1.NAME AS _1, q3.NAME AS _2) } AS q5 RETURN q5 }žDdigraph G {
