---
schema_template:
  CREATE TABLE T1 (id BIGINT, PRIMARY KEY (id))
---
setup:
  steps:
    # Exercises a `setup` step  with three variants. The middle variant uses both `currentVersionAtLeast` and
    # `currentVersionLessThan` to bound a closed-open range; the low and high variants use a single bound each.
    -
      - currentVersionLessThan: "1.0.0.0"
        definition:
          - query: INSERT INTO T1 VALUES (10)
      - currentVersionAtLeast: "1.0.0.0"
        currentVersionLessThan: "100.0.0.0"
        definition:
          - query: INSERT INTO T1 VALUES (50)
      - currentVersionAtLeast: "100.0.0.0"
        definition:
          - query: INSERT INTO T1 VALUES (100)
---
test_block:
  preset: single_repetition_ordered
  tests:
    -
      - query: SELECT id FROM T1
      - result: [{id: !l 50}]
