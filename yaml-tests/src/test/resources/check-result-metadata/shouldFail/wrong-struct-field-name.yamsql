# Failure: struct field is named "WRONG_X" in expected metadata but actual name is "X".
---
schema_template:
    CREATE TYPE AS STRUCT point(x bigint, y bigint)
    CREATE TABLE t1(id bigint, pt point, primary key(id))
---
setup:
  steps:
    - query: INSERT INTO t1 VALUES (1, (10, 20))
---
test_block:
  tests:
    -
      - query: SELECT id, pt FROM t1
      - resultMetadata:
          - {ID: BIGINT}
          - PT:
            - {WRONG_X: BIGINT}
            - {Y: BIGINT}
      - result: [{ID: 1, PT: {X: 10, Y: 20}}]
...
