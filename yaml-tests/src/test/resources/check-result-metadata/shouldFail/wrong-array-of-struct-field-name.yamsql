# Failure: element struct field is named "WRONG_X" but actual name is "X".
---
schema_template:
    CREATE TYPE AS STRUCT point(x bigint, y bigint)
    CREATE TABLE t1(pk integer, pts point array, primary key(pk))
---
setup:
  steps:
    - query: INSERT INTO t1 VALUES (1, [(10, 20)])
---
test_block:
  tests:
    -
      - query: SELECT pk, pts FROM t1
      - resultMetadata: [{PK: INTEGER}, {PTS: {"!array": [{WRONG_X: BIGINT}, {Y: BIGINT}]}}]
      - result: [{1, [{X: 10, Y: 20}]}]
...
