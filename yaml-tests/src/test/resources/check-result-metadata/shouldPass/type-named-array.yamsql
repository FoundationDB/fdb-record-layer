# Struct type whose declared name is "array".
# Verifies that the string "array" used as a struct type-name prefix inside a list
# is not confused with the {array: ...} map syntax used to denote array-typed columns.
---
schema_template:
    CREATE TYPE AS STRUCT "array"(x bigint, y bigint)
    CREATE TABLE t1(id bigint, col "array", pts "array" array, primary key(id))
---
setup:
  steps:
    - query: INSERT INTO t1 VALUES (1, (10, 20), [(10, 20), (30, 40)])
---
test_block:
  tests:
    -
      # Plain struct column — type name "array" as optional prefix inside the field list.
      - query: SELECT id, col FROM t1
      - resultMetadata: [{ID: BIGINT}, {COL: [array, {X: BIGINT}, {Y: BIGINT}]}]
      - result: [{ID: 1, COL: {X: 10, Y: 20}}]
    -
      # Same without the type-name prefix — always valid to omit.
      - query: SELECT id, col FROM t1
      - resultMetadata: [{ID: BIGINT}, {COL: [{X: BIGINT}, {Y: BIGINT}]}]
      - result: [{ID: 1, COL: {X: 10, Y: 20}}]
    -
      # Array-of-struct column where the element struct type is named "array".
      # The outer {array: [...]} is the array marker; "array" inside the list is
      # the struct type-name prefix — distinct levels, no ambiguity.
      - query: SELECT id, pts FROM t1
      - resultMetadata: [{ID: BIGINT}, {PTS: {array: [array, {X: BIGINT}, {Y: BIGINT}]}}]
      - result: [{ID: 1, PTS: [{X: 10, Y: 20}, {X: 30, Y: 40}]}]
...
