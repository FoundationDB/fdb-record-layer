# Happy-path: an array-of-struct column lists the element struct's fields under a "!array": key.
---
schema_template:
    CREATE TYPE AS STRUCT point(x bigint, y bigint)
    CREATE TABLE t1(pk integer, pts point array, primary key(pk))
---
setup:
  steps:
    - query: INSERT INTO t1 VALUES (1, [(10, 20), (30, 40)])
---
test_block:
  tests:
    -
      - query: SELECT pk, pts FROM t1
      - resultMetadata:
          - {PK: INTEGER}
          - PTS:
            - "!array":
              - {X: BIGINT}
              - {Y: BIGINT}
      - result: [{1, [{X: 10, Y: 20}, {X: 30, Y: 40}]}]
...
