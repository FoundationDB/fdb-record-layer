# Struct column where one field is named "array" (a potential reserved word).
# Verifies that {ARRAY: BIGINT} inside a list is not confused with the
# {array: ...} map syntax used to denote array-typed columns.
---
schema_template:
    CREATE TYPE AS STRUCT s("array" bigint, y bigint)
    CREATE TABLE t1(pk integer, col s, primary key(pk))
---
setup:
  steps:
    - query: INSERT INTO t1 VALUES (1, (10, 20))
---
test_block:
  tests:
    -
      # Field name "array" appears as a plain map key inside the struct field list —
      # not as the top-level {array: ...} array marker.
      - query: SELECT pk, col FROM t1
      - resultMetadata: [{PK: INTEGER}, {COL: [{ARRAY: BIGINT}, {Y: BIGINT}]}]
      - result: [{1, {ARRAY: 10, Y: 20}}]
...
