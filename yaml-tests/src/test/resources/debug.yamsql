---
test_block:
  options:
    connection_lifecycle: test
  tests:
    -
      - query: SELECT "msgstate"."mboxRef"."string_value" as "mboxRefValue", "entry"."string_value" AS "category", "msgstate"."isDeleted", "msgstate"."groupKey", max("msgstate"."stateInternalDate") AS "maxDate"
          FROM "msgstate", (SELECT "key"."string_value" FROM "msgstate"."mboxRefUidMap") AS "entry"
          WHERE "msgstate"."___header"."zone_key" = 0 AND "msgstate"."___header"."tombstone" is not true AND "msgstate"."___header"."archived" is not true
          GROUP BY "msgstate"."___header"."zone_key", "msgstate"."mboxRef"."string_value", "entry"."string_value", "msgstate"."isDeleted", "msgstate"."groupKey"
      - debugger: repl
      - explain: "AISCAN(maxDateBySender [EQUALS promote(@c54 AS LONG)] BY_GROUP -> [_0: KEY:[0], _1: KEY:[1], _2: KEY:[2], _3: KEY:[3], _4: KEY:[5], _5: KEY:[4]]) | MAP (_._1 AS mboxRefValue, _._2 AS category, _._3 AS isDeleted, _._4 AS groupKey, _._5 AS maxDate)"
      - result: [
              {mboxRefValue: '31', category: 'inbox1', isDeleted: 0, groupKey: 'sender1', maxDate: 1697574817001},
              {mboxRefValue: '31', category: 'inbox2', isDeleted: 0, groupKey: 'sender1', maxDate: 1697574817001},
              {mboxRefValue: '31', category: 'inbox2', isDeleted: 1, groupKey: 'sender1', maxDate: 1697574818012},
              {mboxRefValue: '31', category: 'inbox2', isDeleted: 1, groupKey: 'sender3', maxDate: 1697574818017},
              {mboxRefValue: '31', category: 'inbox3', isDeleted: 0, groupKey: 'sender1', maxDate: 1697574817001},
              {mboxRefValue: '31', category: 'inbox3', isDeleted: 1, groupKey: 'sender1', maxDate: 1697574818012},
              {mboxRefValue: '31', category: 'inbox30', isDeleted: 0, groupKey: 'sender3', maxDate: 1697574818018},
              {mboxRefValue: '31', category: 'inbox30', isDeleted: 1, groupKey: 'sender3', maxDate: 1697574818017},
              {mboxRefValue: '31', category: 'inbox4', isDeleted: 0, groupKey: 'sender1', maxDate: 1697574817001},
              {mboxRefValue: '31', category: 'inbox4', isDeleted: 1, groupKey: 'sender3', maxDate: 1697574818017},
