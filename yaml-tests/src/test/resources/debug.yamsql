---
# Note that the few fields in the schema template have been explicitly made nullable just because of the lack of
# proper support for `NOT NULL` constraint on fields in Relational layer. Additionally, certain non-nullable arrays
# have been made nullable because of lacking support for array literals in insert statements.
#
# These issues are tracked by the following radars:
#     1. rdar://145133843 (bring back support for NOT NULL constraint on non-array columns)
#     2. rdar://145133877 (add support for array literals in insert statements)
#
# Affected fields are 'bigintList.values' (2), 'RecordHeader.strong_references' (2),
# 'RecordHeader.protection_info_keys_to_remove' (2), 'MapFromReferenceToInt64.values' (2) and 'AssetId.encoded_id' (1)
schema_template:
    CREATE TYPE AS STRUCT "UUID" (
        most_significant_bits bigint,
        least_significant_bits bigint
    )

    CREATE TYPE AS STRUCT Versionstamp(
        versionstamp bytes,
        incarnation integer
    )

    CREATE TYPE AS STRUCT bigintList(
        "values" bigint array
    )

    CREATE TYPE AS STRUCT "RecordHeader"(
        "record_id" string,
        "generation" bigint,
        "type_id" string,
        "type_name" string,
        "type_generation" bigint,
        "creator_dsid" bigint,
        "creator_device_ID" string,
        "ctime" double,
        "mtime" double,
        "tombstone" boolean,
        "original_generation" bigint,
        "modified_by_dsid" bigint,
        "modified_by_device_id" string,
        "has_external_assets" boolean,
        "protection_info" bytes,
        "protection_info_tag" string,
        "expiration_date" bigint,
        "record_ttl" bigint,
        "share_id" string,
        "share_revision_uuid" string,
        "zone_key" bigint,
        "zone_name" string,
        "strong_references" string array,
        "archived" boolean,
        "protection_info_last_roll_timestamp" bigint,
        "protection_info_public_key_id" bytes,
        "emptyTombstone" boolean,
        "protection_info_encrypted_last_roll_date" bytes,
        "protection_info_last_roll_etag_DEPRECATED" string,
        "asset_size" bigint,
        "asset_usage" bigint,
        "should_count_metadata" boolean,
        "dummy_metadata_quota" bigint,
        "blobification_usage" bigint,
        "original_version" Versionstamp,
        "incarnation" integer,
        "blob_id_number" bigint,
        "int64_record_id" bigint,
        "bytes_record_id" bytes,
        "uuid_record_id" "UUID",
        "queue_lease_id" string,
        "queue_vesting_time" double,
        "queue_dequeue_count" integer,
        "queue_priority" bigint,
        "stableUrl" bytes,
        "shareInfo" bytes,
        "protection_info_keys_to_remove" bytes array,
        "original_with_versionstamp" boolean,
        "modified_by_user_id" string,
        "creator_user_id" string
    )

    CREATE TYPE AS STRUCT "AssetId" (
        "encoded_id" bytes,
        "protection_info" bytes,
        "reference_signature" bytes,
        "asset_copy_metadata" bytes,
        "clear_key" bytes
    )

    CREATE TYPE AS ENUM "ReferenceType" ( 'OWNING', 'WEAK', 'VALIDATING' )

    CREATE TYPE AS STRUCT "Reference" (
        "reference_type" "ReferenceType",
        "string_value" STRING,
        "zone_id" STRING,
        "zone_owner_id" STRING
    )

    CREATE TYPE AS STRUCT "ReferenceInt64Pair" (
        "key" "Reference",
        "value" BIGINT
    )

    CREATE TYPE AS STRUCT "MapFromReferenceToInt64" (
        "values" "ReferenceInt64Pair" array
    )

    CREATE TABLE "msgstate" (
    "___header"            "RecordHeader",
    "appleThrId"           STRING,
    "createdModseq"        BIGINT,
    "dataRef"              "Reference",
    "flags"                BIGINT,
    "isDeleted"            BIGINT,
    "isExpunged"           BIGINT,
    "isSeen"               BIGINT,
    "mboxRef"              "Reference",
    "modseq"               BIGINT,
    "senderEmailAddress"   STRING,
    "stateInternalDate"    BIGINT,
    "textSearchRef"        "Reference",
    "uid"                  BIGINT,
    "mboxRefUidMap"        "ReferenceInt64Pair" ARRAY,
    "groupKey"             STRING,
    PRIMARY KEY("___header"."zone_key", "___header"."record_id")
    )

    CREATE INDEX "maxDateBySender" as
    SELECT "msgstate"."___header"."zone_key", "msgstate"."mboxRef"."string_value", "entry"."key"."string_value", "msgstate"."isDeleted", "msgstate"."groupKey", max("msgstate"."stateInternalDate")
    FROM "msgstate", "msgstate"."mboxRefUidMap" AS "entry"
    WHERE "msgstate"."___header"."tombstone" is not true AND "___header"."archived" is not true
    GROUP BY "msgstate"."___header"."zone_key", "msgstate"."mboxRef"."string_value", "entry"."key"."string_value", "msgstate"."isDeleted", "msgstate"."groupKey"
    ORDER BY "msgstate"."___header"."zone_key", "msgstate"."mboxRef"."string_value", "entry"."key"."string_value", "msgstate"."isDeleted", max("msgstate"."stateInternalDate"), "msgstate"."groupKey"

    WITH OPTIONS(ENABLE_LONG_ROWS=true, INTERMINGLE_TABLES=true)
---
setup:
  steps:
    - query: INSERT INTO "msgstate"("___header"("zone_key", "record_id", "tombstone", "archived", "expiration_date"),
                  "appleThrId", "createdModseq", "dataRef"("string_value"), "flags", "isDeleted", "isExpunged", "isSeen", "mboxRef"("string_value"), "modseq", "senderEmailAddress", "stateInternalDate", "textSearchRef"("string_value"), "uid", "mboxRefUidMap", "groupKey")
          VALUES ((0, '17c1c2f8-ef95-487f-8dfd-b8e88bfc27b5', false, false, null), 'thread1', 1000, ('dataRef1'), 16, 0, 0, 0, ('31'), 1000, 'sender@apple.com', 1697574817001, ('textSearchRef1'), 1, [(('OWNING', 'inbox1', null, null), 100), ((null, 'inbox2', null, null), 101), ((null, 'inbox3', null, null), 102), ((null, 'inbox4', null, null), 103)], 'sender1'),
                 ((0, '2e709abe-425f-4212-a32f-6a2ea9874d1d', false, false, null), 'thread1', 1003, ('dataRef2'), 16, 1, 0, 1, ('31'), 1006, 'sender@apple.com', 1697574818012, ('textSearchRef2'), 3, [((null, 'inbox3', null, null), 105), ((null, 'inbox2', null, null), 106), ((null, 'inbox5', null, null), 110)], 'sender1'),
