#
# Purpose: exercise a VECTOR index across a mixed-version (rolling upgrade) deployment. In mixed mode the yaml runner
# alternates each statement between an older external server and the current in-process build. Creating the index and
# then inserting into it forces BOTH versions to load the stored schema-template metadata, which includes the vector
# index's option names (the metric, and the dimensions derived from the vector type). Those option names must be
# readable by both versions. To stay compatible, the shared vector index options keep the legacy hnsw* names as their
# canonical (written) spelling — see the "TEMPORARY (rolling-upgrade wire compatibility)" note in
# VectorIndexOptionKeys. If a newer node instead wrote the engine-neutral vector* names, an older node loading this
# schema to service an insert would fail (e.g. the dimensions option, which has no default, would be missing).
#
# This file deliberately contains only INSERT statements: a KNN SELECT would additionally exercise the windowed
# vector-index query plan, whose continuation/plan-hash is a separate breaking change across versions and would fail
# in mixed mode. Isolating inserts keeps this test focused on the metadata (option-name) compatibility.
#
# Note: supported_version is a concrete (non-!current_version) version so the file actually participates in mixed
# mode; it matches the windowed-vector floor used by window-function-documentation-queries.yamsql.
---
options:
  supported_version: 4.9.3.0
---
schema_template:
    create table documents(zone string, docId string, bookshelf string, title string, embedding vector(3, half), primary key (zone, docId))
    create view documentsView as select embedding, zone, bookshelf, docId, title from documents
    create vector index documentsEuclideanIndex using hnsw on documentsView(embedding) partition by(zone, bookshelf) options (metric = euclidean_metric)
---
test_block:
  name: vector-mixed-version-metadata-inserts
  preset: single_repetition_ordered
  options:
    statement_type: prepared
  tests:
    # Each insert statement is served by the alternating (old/new) connection, so both versions load the vector
    # index metadata and write to the index.
    -
      - query: insert into documents values
              ('zone1', 'd1', 'fiction', 'The Great Gatsby', !! !v16 [1.0, 0.0, 0.0] !!),
              ('zone1', 'd2', 'fiction', '1984', !! !v16 [0.9, 0.1, 0.0] !!),
              ('zone1', 'd3', 'fiction', 'To Kill a Mockingbird', !! !v16 [0.8, 0.2, 0.0] !!)
      - count: 3
    -
      - query: insert into documents values
              ('zone1', 'd6', 'science', 'A Brief History of Time', !! !v16 [0.0, 1.0, 0.0] !!),
              ('zone1', 'd7', 'science', 'The Selfish Gene', !! !v16 [0.1, 0.9, 0.0] !!)
      - count: 2
    -
      - query: insert into documents values
              ('zone1', 'd4', 'fiction', 'Pride and Prejudice', !! !v16 [0.7, 0.3, 0.0] !!)
      - count: 1